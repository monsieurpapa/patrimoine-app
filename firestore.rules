rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Owner = authenticated user with NO roles doc.
    // Manager = authenticated user with roles/{uid}.role == 'manager'.
    // SuperAdmin = authenticated, email-verified user listed in superadmins/{email}.
    //   Bootstrap: create superadmins/{email} manually in Firebase Console — clients cannot write.

    function isOwner() {
      return request.auth != null
          && !exists(/databases/$(database)/documents/roles/$(request.auth.uid));
    }

    function isManager() {
      return request.auth != null
          && exists(/databases/$(database)/documents/roles/$(request.auth.uid))
          && get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role == 'manager';
    }

    function isSuperAdmin() {
      return request.auth != null
          && request.auth.token.email_verified == true
          && exists(/databases/$(database)/documents/superadmins/$(request.auth.token.email));
    }

    // Manager for a specific owner: ownerId must match, OR be null/absent (legacy roles pre-dating this field).
    function isManagerOf(ownerUid) {
      let roleData = get(/databases/$(database)/documents/roles/$(request.auth.uid)).data;
      return isManager()
          && (roleData.get('ownerId', null) == null || roleData.get('ownerId', null) == ownerUid);
    }

    // ---------- SuperAdmin registry (write: false — created manually in Console) ----------
    match /superadmins/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if false;
    }

    // ---------- Owner registry (written on every owner login) ----------
    match /owners/{uid} {
      allow read: if isSuperAdmin();
      allow write: if request.auth != null && request.auth.uid == uid && isOwner();
    }

    // ---------- Patriarch's private data ----------
    // Each collection uses the patriarch's UID as the document ID.
    // Owner with that UID can read/write; superadmin can read all.

    match /assets/{uid} {
      allow read: if (request.auth != null && request.auth.uid == uid && isOwner()) || isSuperAdmin();
      allow write: if request.auth != null && request.auth.uid == uid && isOwner();
    }

    match /transactions/{uid} {
      allow read: if (request.auth != null && request.auth.uid == uid && isOwner()) || isSuperAdmin();
      allow write: if request.auth != null && request.auth.uid == uid && isOwner();
    }

    match /personnel/{uid} {
      allow read: if (request.auth != null && request.auth.uid == uid && isOwner()) || isSuperAdmin();
      allow write: if request.auth != null && request.auth.uid == uid && isOwner();
    }

    match /settings/{uid} {
      allow read: if (request.auth != null && request.auth.uid == uid) || isSuperAdmin();
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ---------- Role assignments ----------
    match /roles/{uid} {
      // Anyone reads their own role; superadmin reads any role
      allow read: if (request.auth != null && request.auth.uid == uid) || isSuperAdmin();

      // Owner can write role docs for OTHER users (patriarch invites a manager)
      allow create, update: if request.auth != null
          && request.auth.uid != uid
          && isOwner();

      // Owner or superadmin can delete a role (revocation)
      allow delete: if (request.auth != null && request.auth.uid != uid && isOwner())
          || isSuperAdmin();

      // Manager claims their OWN role doc when they have a valid pending invite
      allow create: if request.auth != null
          && request.auth.uid == uid
          && request.resource.data.role == 'manager'
          && exists(/databases/$(database)/documents/invites/$(request.auth.token.email))
          && get(/databases/$(database)/documents/invites/$(request.auth.token.email)).data.status == 'pending';
    }

    // ---------- Manager invites (keyed by email) ----------
    match /invites/{email} {
      // Owner sends and manages invites; superadmin can read any invite
      allow create, update, delete: if isOwner();
      allow read: if request.auth != null
          && (request.auth.token.email == email || isOwner() || isSuperAdmin());
    }

    // ---------- Item catalog (retail assets) ----------
    // Owner CRUD; manager reads only their own owner's catalog (ownerId-scoped);
    // legacy managers (ownerId=null in roles doc) retain broad read for backward compat.
    match /catalog/{uid} {
      allow read: if (request.auth != null && request.auth.uid == uid && isOwner())
          || isManagerOf(uid)
          || isSuperAdmin();
      allow write: if request.auth != null && request.auth.uid == uid && isOwner();
    }

    // ---------- Sales sessions ----------
    match /sales/{saleId} {
      allow create: if isManagerOf(request.resource.data.ownerId)
          && request.resource.data.managerId == request.auth.uid
          && request.resource.data.assetId in
             get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.assets.map(a, a.id);
      allow read: if (request.auth != null && resource.data.ownerId == request.auth.uid && isOwner())
          || (isManager() && resource.data.managerId == request.auth.uid)
          || isSuperAdmin();
      allow update: if isOwner();
      allow delete: if false;
    }

    // ---------- Manager reports ----------
    match /reports/{reportId} {
      // Manager submits a report only for an asset explicitly assigned to them
      allow create: if isManager()
          && request.resource.data.managerId == request.auth.uid
          && request.resource.data.assetId in
             get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.assets.map(a, a.id);

      // Manager reads their own reports; owner and superadmin read all reports
      allow read: if request.auth != null
          && (resource.data.managerId == request.auth.uid || isOwner() || isSuperAdmin());

      // Owner marks reports as reviewed
      allow update: if isOwner();

      // No deletions — reports are permanent records
      allow delete: if false;
    }
  }
}
